GITHUB_PERSONAL_ACCESS_TOKEN=   # Required — GitHub PAT with repo + project scopes

# --- OAuth 2.0 Authentication (REQUIRED) ---
OAUTH_CLIENT_ID=                # Required — OAuth Client ID for Claude.ai connector auth
OAUTH_CLIENT_SECRET=            # Required — OAuth Client Secret (used to sign/verify JWT tokens)

# Both OAUTH_CLIENT_ID and OAUTH_CLIENT_SECRET are mandatory.
# The server will refuse to start if either is missing.

PORT=5000                       # Optional, default 5000
